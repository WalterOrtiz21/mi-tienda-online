# .env.example - Plantilla de configuración
# Copiar a .env.local para desarrollo. En Vercel, cargar como Environment Variables.

# ==============================================
# SUPABASE (requerido)
# ==============================================
# Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co

# Project Settings → API Keys → Publishable key (sb_publishable_...)
# Es seguro exponerla al cliente. Respeta RLS.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Project Settings → API Keys → Secret key (sb_secret_...)
# NUNCA exponer al cliente. Bypass RLS. Solo en server.
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxx

# ==============================================
# AUTH DEL ADMIN PANEL
# ==============================================
# Password del panel /admin
ADMIN_PASSWORD=your_admin_password_here
